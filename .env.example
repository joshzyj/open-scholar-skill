# Open-Scholar-Skill Configuration
# Copy to .env and adjust paths for your machine.
# Run `bash setup.sh` for guided setup (recommended).

# Path to the open-scholar-skill installation directory (REQUIRED for cross-project use)
# setup.sh auto-detects this and adds it as an export in your shell profile (~/.zshrc or ~/.bashrc).
# SCHOLAR_SKILL_DIR=/path/to/open-scholar-skill

# Zotero library directory (containing zotero.sqlite)
# Auto-detected at: ~/Zotero, ~/Library/CloudStorage/*/zotero, etc.
# SCHOLAR_ZOTERO_DIR=/path/to/zotero

# BibTeX .bib file path (optional)
# SCHOLAR_BIB_PATH=/path/to/library.bib

# EndNote XML export path (optional)
# SCHOLAR_ENDNOTE_XML=/path/to/library.xml

# CrossRef / OpenAlex polite pool email (STRONGLY recommended)
# Without this, CrossRef API imposes strict rate limits that slow citation verification.
# SCHOLAR_CROSSREF_EMAIL=your.email@institution.edu

# Open data API keys (required for auto-fetch in scholar-data / scholar-analyze)
# Census API key — required for tidycensus (ACS, Census, CPS)
# Get free key at: https://api.census.gov/data/key_signup.html
# CENSUS_API_KEY=your_census_api_key_here

# FRED API key — required for fredr (Federal Reserve Economic Data)
# Get free key at: https://fred.stlouisfed.org/docs/api/api_key.html
# FRED_API_KEY=your_fred_api_key_here

# Semantic Scholar API key (optional — higher rate limits)
# Request at: https://www.semanticscholar.org/product/api#api-key
# S2_API_KEY=your_s2_api_key_here

# HuggingFace token for SciThinker-30B in /scholar-brainstorm PAPER mode (optional — skill falls back to Claude-only ideation)
# HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxx

# Knowledge graph directory (user-scoped, cross-project)
# Default: ~/.claude/scholar-knowledge
# SCHOLAR_KNOWLEDGE_DIR=${HOME}/.claude/scholar-knowledge

# Output root directory (per-project, used by all skills for saving tables, figures, logs, drafts)
# Default: "output" (relative to current working directory)
# OUTPUT_ROOT=output

# Visualization engine preference (optional)
# Set to "python" to default to matplotlib/seaborn instead of ggplot2/R
# Default: R (ggplot2)
# VIZ_ENGINE=python
